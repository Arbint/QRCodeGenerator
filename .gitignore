# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Poetry-specific
.poetry/
poetry.lock  # optional: ignore only if you don't want lockfile versioned (recommended to keep!)

# Virtual environments
# If you set Poetry to create venvs inside the project (virtualenvs.in-project = true)
.venv/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Type checker caches
.mypy_cache/
.dmypy.json
dmypy.json

# Linting / formatting
.ruff_cache/
.pyre/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db